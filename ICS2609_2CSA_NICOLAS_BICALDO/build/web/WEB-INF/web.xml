<?xml version="1.0" encoding="UTF-8"?>
<web-app version="2.5" xmlns="http://java.sun.com/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd">
    <context-param>
        <param-name>headerText</param-name>
        <param-value>
            
            &lt;style&gt;
                body {
                    font-family: 'Helvetica Neue', Arial, sans-serif;
                    color: #111;
                    background-color: #fff;
                    margin: 0;
                    padding: 0;
                    line-height: 1.6;
                }
                h1, h2, h3 {
                    font-family: 'Georgia', Times, serif;
                    font-weight: bold;
                    color: #000;
                }
                h2 { font-size: 3.5rem; margin-top: 0; margin-bottom: 1rem; }
                h3 { font-size: 2rem; margin-bottom: 0.5rem; }
                
                .header {
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    padding: 2rem 5%;
                }
                .title {
                    font-size: 1.2rem;
                    letter-spacing: 3px;
                    text-transform: uppercase;
                    font-weight: normal;
                }
                
                button, .btn {
                    border-radius: 50px;
                    border: 2px solid #000;
                    background-color: transparent;
                    color: #000;
                    padding: 12px 28px;
                    text-transform: uppercase;
                    font-weight: bold;
                    font-size: 0.8rem;
                    letter-spacing: 1px;
                    cursor: pointer;
                    transition: all 0.3s ease;
                    text-decoration: none;
                    display: inline-block;
                }
                button:hover, .btn:hover {
                    background-color: #000;
                    color: #fff;
                }

                input[type="text"], input[type="password"], select {
                    border: none;
                    border-bottom: 1px solid #ccc;
                    padding: 10px 5px;
                    font-size: 1rem;
                    width: 100%;
                    max-width: 300px;
                    margin-bottom: 1.5rem;
                    outline: none;
                }
                input:focus, select:focus { border-bottom-color: #000; }
                fieldset { border: 1px solid #eee; padding: 2rem; border-radius: 8px; margin-top: 2rem; }
                legend { font-weight: bold; padding: 0 10px; }
            &lt;/style&gt;
            
            &lt;header class="header"&gt;
                &lt;div class="title"&gt;Header&lt;/div&gt;
            &lt;/header&gt;
            &lt;div class="container"&gt;
            
        </param-value>
    </context-param>
    <context-param>
        <param-name>footerText</param-name>
        <param-value>
            
            &lt;/div&gt; &lt;footer style="text-align: center; padding: 3rem; color: #888; font-size: 0.8rem;"&gt;
                &lt;p&gt;Footer&lt;/p&gt;
            &lt;/footer&gt;
            
        </param-value>
    </context-param>
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>servlet.LoginServlet</servlet-class>
        <init-param>
            <param-name>dbUrl</param-name>
            <param-value>jdbc:derby://localhost:1527/LoginDB</param-value>
        </init-param>
        <init-param>
            <param-name>dbUser</param-name>
            <param-value>app</param-value>
        </init-param>
        <init-param>
            <param-name>dbPassword</param-name>
            <param-value>app</param-value>
        </init-param>
        <init-param>
            <param-name>dbDriver</param-name>
            <param-value>org.apache.derby.jdbc.ClientDriver</param-value>
        </init-param>
    </servlet>
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>servlet.DashboardServlet</servlet-class>
        <init-param>
            <param-name>dbUrl</param-name>
            <param-value>jdbc:derby://localhost:1527/LoginDB</param-value>
        </init-param>
        <init-param>
            <param-name>dbUser</param-name>
            <param-value>app</param-value>
        </init-param>
        <init-param>
            <param-name>dbPassword</param-name>
            <param-value>app</param-value>
        </init-param>
        <init-param>
            <param-name>dbDriver</param-name>
            <param-value>org.apache.derby.jdbc.ClientDriver</param-value>
        </init-param>
    </servlet>
    <servlet>
        <servlet-name>InsertServlet</servlet-name>
        <servlet-class>servlet.InsertServlet</servlet-class>
        <init-param>
            <param-name>dbUrl</param-name>
            <param-value>jdbc:derby://localhost:1527/LoginDB</param-value>
        </init-param>
        <init-param>
            <param-name>dbUser</param-name>
            <param-value>app</param-value>
        </init-param>
        <init-param>
            <param-name>dbPassword</param-name>
            <param-value>app</param-value>
        </init-param>
        <init-param>
            <param-name>dbDriver</param-name>
            <param-value>org.apache.derby.jdbc.ClientDriver</param-value>
        </init-param>
    </servlet>
    <servlet>
        <servlet-name>DeleteServlet</servlet-name>
        <servlet-class>servlet.DeleteServlet</servlet-class>
        <init-param>
            <param-name>dbUrl</param-name>
            <param-value>jdbc:derby://localhost:1527/LoginDB</param-value>
        </init-param>
        <init-param>
            <param-name>dbUser</param-name>
            <param-value>app</param-value>
        </init-param>
        <init-param>
            <param-name>dbPassword</param-name>
            <param-value>app</param-value>
        </init-param>
        <init-param>
            <param-name>dbDriver</param-name>
            <param-value>org.apache.derby.jdbc.ClientDriver</param-value>
        </init-param>
    </servlet>
    <servlet>
        <servlet-name>UpdateServlet</servlet-name>
        <servlet-class>servlet.UpdateServlet</servlet-class>
        <init-param>
            <param-name>dbUrl</param-name>
            <param-value>jdbc:derby://localhost:1527/LoginDB</param-value>
        </init-param>
        <init-param>
            <param-name>dbUser</param-name>
            <param-value>app</param-value>
        </init-param>
        <init-param>
            <param-name>dbPassword</param-name>
            <param-value>app</param-value>
        </init-param>
        <init-param>
            <param-name>dbDriver</param-name>
            <param-value>org.apache.derby.jdbc.ClientDriver</param-value>
        </init-param>
    </servlet>
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>servlet.LogoutServlet</servlet-class>
        <init-param>
            <param-name>dbUrl</param-name>
            <param-value>jdbc:derby://localhost:1527/LoginDB</param-value>
        </init-param>
        <init-param>
            <param-name>dbUser</param-name>
            <param-value>app</param-value>
        </init-param>
        <init-param>
            <param-name>dbPassword</param-name>
            <param-value>app</param-value>
        </init-param>
        <init-param>
            <param-name>dbDriver</param-name>
            <param-value>org.apache.derby.jdbc.ClientDriver</param-value>
        </init-param>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>InsertServlet</servlet-name>
        <url-pattern>/InsertServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DeleteServlet</servlet-name>
        <url-pattern>/DeleteServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UpdateServlet</servlet-name>
        <url-pattern>/UpdateServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/LogoutServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/DashboardServlet</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            5
        </session-timeout>
    </session-config>
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
    <error-page>
        <error-code>404</error-code>
        <location>/error_4.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/error_500.jsp</location>
    </error-page>
    <error-page>
        <exception-type>exception.NullValueException</exception-type>
        <location>/noLoginCredentials.jsp</location>
    </error-page>
    <error-page>
        <exception-type>exception.AuthenticationException</exception-type>
        <location>/error_2.jsp</location>
    </error-page>
    <error-page>
        <exception-type>java.lang.Exception</exception-type>
        <location>/error_session.jsp</location>
    </error-page>
</web-app>
